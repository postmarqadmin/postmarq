{
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/", "destination": "/my-post.html" },
    { "source": "/home", "destination": "/my-post.html" },
    { "source": "/login", "destination": "/login.html" },
    { "source": "/((?!.*\\.).*)", "destination": "/viewer.html" }
  ]
}
